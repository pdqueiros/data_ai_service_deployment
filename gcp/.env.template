# Copy to .env and fill in, then `source gcp/.env` before running the checklist in gcp/README.md.
# .env is git-ignored; never commit real values.

# --- Project ---
export PROJECT_ID=""            # e.g. scryn-co
export PROJECT_NUMBER=""        # gcloud projects describe $PROJECT_ID --format='value(projectNumber)'

# --- Artifact Registry ---
export REGION=""                # e.g. europe-west1 (AR + Cloud Build region)
export ARTIFACT_REGISTRY_DOCKER=""        # e.g. docker-nonprod
export ARTIFACT_REGISTRY_PYPI=""          # e.g. pypi-internal
export IMAGE_NAME=""            # e.g. scryn-pipeline (builder image name)

# --- Cloud Build service account ---
# check available ones with # gcloud iam service-accounts list --project="$PROJECT_ID"   --format='table(email,disabled,displayName)'
export CLOUD_BUILD_SA=""

# --- GitHub 2nd-gen connection (see README.md § 2.5) ---
export CONNECTION_NAME=""       # Cloud Build host connection name
